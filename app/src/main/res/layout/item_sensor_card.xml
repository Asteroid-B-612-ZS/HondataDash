<?xml version="1.0" encoding="utf-8"?>
<!--
    传感器卡片 V5 - 整数/小数分体字体
    顶部: 英文缩写(左) + 单位(右上角右对齐, 同标题大小)
    中央: 大数值(整数68sp + 小数60sp) + MAX/MIN(右, 纯数字24sp)
    底部: 刻度进度条 (刻度在上方)
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_card"
    android:padding="4dp">

    <!-- 顶部: 标题(单位) 紧凑排列 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/labelEn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFCCCCCC"
            android:textSize="18sp"
            android:textStyle="bold"
            android:singleLine="true"/>

        <TextView
            android:id="@+id/unit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFBBBBBB"
            android:textSize="18sp"
            android:includeFontPadding="false"
            android:singleLine="true"
            android:gravity="center_vertical"/>
    </LinearLayout>

    <!-- 中央: 数值(左4/5) + MAX/MIN(右1/5) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- 数值 (左侧, 占2/3) -->
        <LinearLayout
            android:id="@+id/valueArea"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="4.0"
            android:orientation="horizontal"
            android:gravity="center_vertical|start"
            android:baselineAligned="false"
            android:paddingStart="2dp">

            <TextView
                android:id="@+id/valueInt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFFFF"
                android:textSize="65sp"
                android:textStyle="bold|italic"
                android:includeFontPadding="false"
                android:singleLine="true"
                android:ellipsize="none"
                android:text="--"/>

            <TextView
                android:id="@+id/valueDec"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:textColor="#FFFFFFFF"
                android:textSize="65sp"
                android:textStyle="bold|italic"
                android:includeFontPadding="false"
                android:singleLine="true"
                android:ellipsize="none"/>

        </LinearLayout>

        <!-- MAX / MIN (右侧右对齐, MAX靠上 MIN靠下) -->
        <LinearLayout
            android:id="@+id/extremePanel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.0"
            android:orientation="vertical"
            android:gravity="end"
            android:paddingEnd="2dp">

            <TextView
                android:id="@+id/maxValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFBBBBBB"
                android:textSize="24sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:text=""/>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <TextView
                android:id="@+id/minValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFAAAAAA"
                android:textSize="24sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:text=""/>
        </LinearLayout>
    </LinearLayout>

    <!-- 底部: 刻度进度条 (刻度在上方) -->
    <com.hondata.dash.ScaleBarView
        android:id="@+id/scaleBar"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:paddingLeft="2dp"
        android:paddingRight="2dp"/>

</LinearLayout>

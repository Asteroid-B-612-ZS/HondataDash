<?xml version="1.0" encoding="utf-8"?>
<!--
    传感器卡片 V7 - FrameLayout overlay 架构
    顶部: 英文缩写(左) + 单位(右上角右对齐, 同标题大小)
    中央: FrameLayout(normalValueLayer + semanticValue overlay)
      - normalValueLayer: 主值(单TextView) + MAX/MIN(固定56dp, 18sp)
      - semanticValue: DFCO/SYNC overlay (INVISIBLE/VISIBLE切换)
    底部: 刻度进度条 (刻度在上方)
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_card"
    android:padding="4dp">

    <!-- 顶部: 标题(单位) 紧凑排列 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/labelEn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFCCCCCC"
            android:textSize="18sp"
            android:textStyle="bold"
            android:singleLine="true"/>

        <TextView
            android:id="@+id/unit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFBBBBBB"
            android:textSize="18sp"
            android:includeFontPadding="false"
            android:singleLine="true"
            android:gravity="center_vertical"/>
    </LinearLayout>

    <!-- 中央: FrameLayout overlay — 正常层 + 语义层 -->
    <FrameLayout
        android:id="@+id/valueCenterFrame"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- 正常数据层：主值 + MAX/MIN -->
        <LinearLayout
            android:id="@+id/normalValueLayer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- 主值区：吃掉剩余空间 -->
            <FrameLayout
                android:id="@+id/valueArea"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:clipChildren="true"
                android:clipToPadding="true">

                <TextView
                    android:id="@+id/valueInt"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:textColor="#FFFFFFFF"
                    android:textSize="100sp"
                    android:textStyle="bold|italic"
                    android:includeFontPadding="false"
                    android:singleLine="true"
                    android:ellipsize="none"
                    android:gravity="center_vertical|start"
                    android:text="--"/>
            </FrameLayout>

            <!-- 右侧 MAX/MIN：固定宽度，稳定显示 -->
            <LinearLayout
                android:id="@+id/extremePanel"
                android:layout_width="56dp"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="end"
                android:paddingEnd="2dp"
                android:clipChildren="true"
                android:clipToPadding="true">

                <TextView
                    android:id="@+id/maxValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFBBBBBB"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:includeFontPadding="false"
                    android:singleLine="true"
                    android:ellipsize="none"
                    android:gravity="end"
                    android:text=""/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>

                <TextView
                    android:id="@+id/minValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFAAAAAA"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:includeFontPadding="false"
                    android:singleLine="true"
                    android:ellipsize="none"
                    android:gravity="end"
                    android:text=""/>
            </LinearLayout>
        </LinearLayout>

        <!-- 语义标签层：DFCO / SYNC，覆盖整块中央区域 -->
        <TextView
            android:id="@+id/semanticValue"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="invisible"
            android:textColor="#FFA0A0A0"
            android:textSize="82sp"
            android:textStyle="bold|italic"
            android:includeFontPadding="false"
            android:singleLine="true"
            android:ellipsize="none"
            android:gravity="center_vertical|start"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:text=""/>

        <!-- 隐藏的 valueDec，Java 兼容保留 -->
        <TextView
            android:id="@+id/valueDec"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"/>
    </FrameLayout>

    <!-- 底部: 刻度进度条 (刻度在上方) -->
    <com.hondata.dash.ScaleBarView
        android:id="@+id/scaleBar"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:paddingLeft="2dp"
        android:paddingRight="2dp"/>

</LinearLayout>
